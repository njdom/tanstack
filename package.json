{
  "name": ".",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "db:seed": "tsx src/server/seed.ts",
    "db:shell": "docker exec -it tanstack-mongodb mongosh -u admin -p admin123 --authenticationDatabase admin tanstack_products",
